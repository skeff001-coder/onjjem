modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["revenuecat:1.0.0", "stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 6000

[[ports]]
localPort = 3001
externalPort = 6800

[[ports]]
localPort = 3002
externalPort = 8000

[[ports]]
localPort = 3005
externalPort = 8008

[[ports]]
localPort = 3006
externalPort = 8081

[[ports]]
localPort = 8080
externalPort = 8080

